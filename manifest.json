{
  "manifest_version": 3,
  "name": "UoM GPA Calculator",
  "version": "1.0",
  "description": "Calculates overall GPA on UoM results page",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://lms.uom.lk/mis_exam/reports/view_my_results.php*"
      ],
      "js": ["gpa.js"],
      "run_at": "document_idle"
    }
  ]
}
