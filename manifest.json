{
  "manifest_version": 3,
  "name": "UWU GPA Calculator",
  "version": "1.0.0",
  "description": "Automatically calculates SGPA per semester and overall GPA on the UWU examination results portal.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://exam.uwu.ac.lk/ug/user/*"],
      "js": ["gpa.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
